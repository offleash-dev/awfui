# ----------------------------------------
# Normalize line endings across platforms
# ----------------------------------------

# Source files: always LF
*.cpp   text eol=lf
*.h     text eol=lf
*.c     text eol=lf
*.hpp   text eol=lf

# Scripts: always LF
*.sh    text eol=lf
*.py    text eol=lf

# Windows scripts: CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Build files
CMakeLists.txt text eol=lf
*.cmake        text eol=lf

# Config files
*.clang-format text eol=lf
*.editorconfig text eol=lf

# Markdown, docs, JSON, YAML: LF
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary files (no normalization)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.bin   binary
